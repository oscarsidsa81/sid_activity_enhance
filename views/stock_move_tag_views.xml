<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="sid_view_stock_move_tree_tags" model="ir.ui.view">
            <field name="name">sid.stock.move.tree.tags</field>
            <field name="model">stock.move</field>
            <field name="inherit_id" ref="stock.view_move_tree"/>
            <field name="priority">95</field>
            <field name="arch" type="xml">
                <xpath expr="//tree" position="inside">
                    <field name="sid_activity_tag_ids" widget="many2many_tags" optional="show"
                           options="{'color_field': 'color'}"/>
                </xpath>
            </field>
        </record>

        <record id="sid_view_stock_move_tree_tags" model="ir.ui.view">
            <field name="name">sid.stock.move.activity.tree.tags</field>
            <field name="model">stock.move</field>
            <field name="inherit_id" ref="sid_stock_views_ov.view_stock_move_tree_ov"/>
            <field name="priority">10</field>
            <field name="arch" type="xml">
                <xpath expr="//tree" position="inside">
                    <field name="sid_activity_tag_ids" widget="many2many_tags" optional="show"
                           options="{'color_field': 'color'}"/>
                </xpath>
            </field>
        </record>

        <record id="sid_view_stock_move_form_tags" model="ir.ui.view">
            <field name="name">sid.stock.move.form.tags</field>
            <field name="model">stock.move</field>
            <field name="inherit_id" ref="stock.view_move_form"/>
            <field name="priority">95</field>
            <field name="arch" type="xml">
                <xpath expr="//sheet/group" position="inside">
                    <field name="sid_activity_tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"
                           readonly="1"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
